{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LibreA11y",
  "version": "0.1.0",
  "identifier": "ca.pgrg.librea11y",
  "build": {
    "frontendDist": "../site"
  },
  "app": {
    "windows": [
      {
        "title": "LibreA11y",
        "width": 1100,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico",
      "icons/icon.icns",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ],
    "category": "Utility",
    "shortDescription": "Suite d'accessibilite numerique libre et hors-ligne",
    "longDescription": "15 applications d'accessibilite numerique gratuites, open source et fonctionnant hors-ligne. Pour les personnes sourdes, aveugles, dyslexiques, avec des troubles moteurs ou cognitifs.",
    "copyright": "PGRG IA — Licence GPL-3.0",
    "linux": {
      "deb": {
        "depends": []
      },
      "appimage": {
        "bundleMediaFramework": true
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "digestAlgorithm": "sha256",
      "certificateThumbprint": null,
      "timestampUrl": "",
      "wix": {
        "language": "fr-FR"
      }
    }
  }
}
